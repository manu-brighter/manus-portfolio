{
  "name": "manus-portfolio",
  "version": "0.1.0",
  "private": true,
  "description": "Manuel Heller — Craft Portfolio \"Toon Fluid\"",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22.14.0"
  },
  "scripts": {
    "dev": "node node_modules/next/dist/bin/next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check . && node scripts/check-layering.mjs",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "playwright test --grep-invert @visual",
    "test:a11y": "playwright test --grep @a11y",
    "test:visual": "playwright test --grep @visual",
    "lighthouse": "lhci autorun",
    "ci:local": "pnpm lint && pnpm typecheck && pnpm build && cross-env E2E_TARGET=prod pnpm test",
    "prepare": "node scripts/install-git-hooks.mjs"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.3.0",
    "@fontsource-variable/jetbrains-mono": "^5.3.0",
    "@fontsource/instrument-serif": "^5.3.0",
    "@gsap/react": "^2.1.2",
    "@next/mdx": "^16.2.10",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "clsx": "^2.1.1",
    "gsap": "^3.15.0",
    "lenis": "^1.3.25",
    "next": "^16.2.10",
    "next-intl": "^4.13.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rehype-pretty-code": "^0.14.4",
    "shiki": "^4.3.1",
    "three": "^0.185.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@biomejs/biome": "^2.5.4",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.3",
    "@tweakpane/core": "^2.0.5",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.1.0",
    "@types/three": "^0.185.1",
    "cross-env": "^10.1.0",
    "postcss": "^8.5.20",
    "raw-loader": "^4.0.2",
    "tailwindcss": "^4.3.3",
    "tweakpane": "^4.0.5",
    "typescript": "^7.0.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@swc/core",
      "esbuild",
      "protobufjs",
      "sharp"
    ]
  }
}
