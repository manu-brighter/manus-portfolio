{
  "name": "manus-portfolio",
  "version": "0.1.0",
  "private": true,
  "description": "Manuel Heller — Craft Portfolio \"Toon Fluid\"",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22.14.0"
  },
  "scripts": {
    "dev": "node node_modules/next/dist/bin/next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "playwright test --grep-invert @visual",
    "test:a11y": "playwright test --grep @a11y",
    "test:visual": "playwright test --grep @visual",
    "lighthouse": "lhci autorun",
    "ci:local": "pnpm lint && pnpm typecheck && pnpm build && E2E_TARGET=prod pnpm test",
    "prepare": "node scripts/install-git-hooks.mjs"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource/instrument-serif": "^5.2.8",
    "@gsap/react": "^2.1.2",
    "@next/mdx": "^16.2.5",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "clsx": "^2.1.1",
    "contentlayer2": "^0.5.8",
    "gsap": "^3.15.0",
    "lenis": "^1.3.23",
    "next": "^16.2.5",
    "next-intl": "^4.11.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "rehype-pretty-code": "^0.14.3",
    "shiki": "^4.0.2",
    "three": "^0.184.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@biomejs/biome": "^2.4.14",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/three": "^0.184.0",
    "leva": "^0.10.1",
    "postcss": "^8.5.14",
    "raw-loader": "^4.0.2",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.7.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@swc/core",
      "contentlayer2",
      "esbuild",
      "protobufjs",
      "sharp"
    ]
  }
}
